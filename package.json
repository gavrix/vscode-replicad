{
  "name": "vscode-replicad-preview",
  "displayName": "Replicad Preview",
  "description": "Preview Replicad models beside the native VS Code editor.",
  "version": "0.0.1",
  "publisher": "gavrix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gavrix/vscode-replicad.git"
  },
  "homepage": "https://github.com/gavrix/vscode-replicad",
  "bugs": {
    "url": "https://github.com/gavrix/vscode-replicad/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "replicad",
    "cad",
    "preview",
    "3d",
    "opencascade"
  ],
  "activationEvents": [
    "onCommand:replicadPreview.openPreview",
    "onCommand:replicadPreview.openPreviewToSide",
    "onCommand:replicadPreview.toggleAutoPreview",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "media/**",
    "runtime/**",
    "README.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "replicadPreview.openPreview",
        "title": "Replicad: Open Preview"
      },
      {
        "command": "replicadPreview.openPreviewToSide",
        "title": "Replicad: Open Preview to the Side"
      },
      {
        "command": "replicadPreview.toggleAutoPreview",
        "title": "Replicad: Toggle Auto Preview"
      }
    ],
    "configuration": {
      "title": "Replicad Preview",
      "properties": {
        "replicadPreview.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open or retarget the Replicad preview when a matching editor becomes active."
        },
        "replicadPreview.fileExtensions": {
          "type": "array",
          "default": [
            ".js",
            ".jsx",
            ".ts",
            ".tsx",
            ".mjs",
            ".mts"
          ],
          "items": {
            "type": "string"
          },
          "description": "File extensions considered for Replicad preview heuristics."
        },
        "replicadPreview.debounceMs": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "description": "Debounce delay before pushing document updates to the preview."
        },
        "replicadPreview.refreshOnSaveOnly": {
          "type": "boolean",
          "default": true,
          "description": "Only rebuild the preview when the file is saved."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "prepare:runtime": "rm -rf runtime/node_modules runtime/package-lock.json && cd runtime && npm install --omit=dev",
    "build": "npm run package:vsix",
    "package:vsix": "npm run prepare:runtime && vsce package --no-dependencies --allow-missing-repository --skip-license",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.1"
  },
  "dependencies": {
    "esbuild": "^0.27.4",
    "replicad": "^0.21.1",
    "replicad-opencascadejs": "^0.21.0",
    "three": "^0.183.2",
    "typescript": "^5.8.2"
  }
}
